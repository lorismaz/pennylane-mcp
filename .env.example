# Pennylane MCP — environment configuration
# Copy this file to ".env" (same folder as server.py) and fill in real tokens.
# server.py AUTO-LOADS this .env — you do NOT need to `source` it.
# Generate a Company API token in Pennylane: Settings -> Connectivity / API.
# NEVER commit your real .env to version control.

# --- Option A (recommended): one quote-free variable per company ---
# Simplest and shell-safe — no JSON, no quoting headaches.
PENNYLANE_API_KEY_ACME=REPLACE_WITH_ACME_TOKEN
PENNYLANE_API_KEY_BETA=REPLACE_WITH_BETA_TOKEN
PENNYLANE_DEFAULT_COMPANY=acme

# --- Option B: a single JSON variable ---
# Note the SINGLE quotes around the JSON. They matter if you ever `source` this
# file in bash (without them, the shell strips the inner double quotes and the
# value stops being valid JSON). Auto-load handles either form.
# PENNYLANE_COMPANIES='{"acme":"REPLACE_WITH_ACME_TOKEN","beta":"REPLACE_WITH_BETA_TOKEN"}'

# --- Option C: a single company ---
# PENNYLANE_API_KEY=REPLACE_WITH_TOKEN
# PENNYLANE_COMPANY_NAME=acme

# --- Option D: accounting firm (cabinet) — Firm API ---
# A firm token works across ALL the firm's client companies via the separate
# Firm API and unlocks the pennylane_firm_* tools. Generate it in Pennylane:
# Firm settings -> Firm Tokens. Combinable with any option above.
# PENNYLANE_FIRM_API_KEY=REPLACE_WITH_FIRM_TOKEN
# Optional: client company (dossier) ID used when a tool call omits company_id.
# Find IDs with the pennylane_firm_list_companies tool.
# PENNYLANE_FIRM_DEFAULT_COMPANY_ID=12345

# --- Optional ---
# Opt in/out of the 2026 API behavior changes (default: true; Company v2 only).
# PENNYLANE_USE_2026_CHANGES=true
# Override the API base URLs (rarely needed).
# PENNYLANE_API_BASE_URL=https://app.pennylane.com/api/external/v2
# PENNYLANE_FIRM_API_BASE_URL=https://app.pennylane.com/api/external/firm/v1
